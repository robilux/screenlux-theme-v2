{{ 'section-compare-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'component-compare-slider.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding screenlux-product-container compare-section">
    <div class="compare-header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.heading != blank -%}
        <h2 class="compare-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <div class="compare-subheading rte">{{ section.settings.subheading }}</div>
      {%- endif -%}
    </div>

    <compare-slider class="compare-slider-component{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="compare-wrapper">
        <div class="compare-image compare-after">
          {%- if section.settings.image_2 != blank -%}
            {{
              section.settings.image_2
              | image_url: width: 1500
              | image_tag: loading: 'lazy', sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
            }}
          {%- else -%}
            <img
              src="{{ 'img-screenlux-compare-section-screen.jpg' | asset_url }}"
              loading="lazy"
              width="1500"
              height="auto"
              alt="Screenlux Screen"
            >
          {%- endif -%}
          <span class="compare-label compare-label-right">Screenlux</span>
        </div>

        <div class="compare-image compare-before">
          {%- if section.settings.image_1 != blank -%}
            {{
              section.settings.image_1
              | image_url: width: 1500
              | image_tag: loading: 'lazy', sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
            }}
          {%- else -%}
            <img
              src="{{ 'img-screenlux-compare-section-roller-shutter.jpg' | asset_url }}"
              loading="lazy"
              width="1500"
              height="auto"
              alt="Roller Shutter"
            >
          {%- endif -%}
          <span class="compare-label compare-label-left">Roller Shutter</span>
        </div>

        <div class="compare-handle-container">
          <div class="compare-handle">
            <svg width="41" height="32" viewBox="0 0 41 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16.5 11L11.5 16L16.5 21" stroke="#171717" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M24.5 11L29.5 16L24.5 21" stroke="#171717" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <input type="range" min="0" max="100" value="50" class="compare-range" aria-label="Comparison slider">
      </div>
    </compare-slider>

    <div class="compare-cta{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- liquid
        assign cta_text = section.settings.cta_text
        assign cta_url = section.settings.cta_url
        assign cta_subtext = section.settings.cta_subtext
        assign price_color = '#000000'
        assign show_secondary = false

        if section.settings.use_global_buttons
          assign cta_text = settings.global_primary_button_label
          assign cta_url = settings.global_primary_button_link
          assign cta_subtext = settings.global_price_label

          if settings.global_price_label_auto_color
            assign bg_color = section.settings.bg_color | default: '#ffffff'
            if bg_color == blank or bg_color == 'rgba(0,0,0,0)'
              assign bg_color = '#ffffff'
            endif
            assign brightness = bg_color | color_brightness
            if brightness < 128
              assign price_color = '#ffffff'
            else
              assign price_color = '#000000'
            endif
          endif

          if settings.show_global_secondary_button
            assign show_secondary = true
            assign secondary_cta_text = settings.global_secondary_button_label
            assign secondary_cta_url = settings.global_secondary_button_link
          endif
        endif
      -%}
      
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; width: 100%;">
        {%- if cta_text != blank and cta_url != blank -%}
          <a href="{{ cta_url }}" class="button--brand">{{ cta_text }}</a>
        {%- endif -%}
        {%- if show_secondary and secondary_cta_text != blank and secondary_cta_url != blank -%}
          <a href="{{ secondary_cta_url }}" class="button--brand-secondary">{{ secondary_cta_text }}</a>
        {%- endif -%}
      </div>
      
      {%- if cta_subtext != blank -%}
        <div class="compare-cta-subtext rte" style="margin-top: 12px; color: {{ price_color }};">{{ cta_subtext }}</div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Compare Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_global_buttons",
      "label": "Use Global Theme Buttons",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Keep the heat out, not the light.",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "default": "<p>Traditional roller shutters require total darkness to be effective. Screenlux ZIP blocks <strong>95% of heat</strong> and <strong>98% of UV rays</strong> before it hits the glass – keeping you cool without losing the light.</p>",
      "label": "Subheading"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Before Image (Roller Shutter)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "After Image (Screenlux)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "default": "Configure",
      "label": "Local Button Label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Local Button Link"
    },
    {
      "type": "richtext",
      "id": "cta_subtext",
      "default": "<p>From only <em>395€</em></p>",
      "label": "Button Subtext"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Compare Slider"
    }
  ]
}
{% endschema %}
