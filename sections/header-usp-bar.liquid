<div class="sl-header-bar">
  <div class="page-width sl-header-bar__inner">
    <div class="sl-header-bar__left">
      <span class="sl-header-bar__usp">{{ section.settings.usp_text }}</span>
    </div>

    <div class="sl-header-bar__right">
      <span class="sl-header-bar__status">{{ section.settings.status_text }}</span>
      <a class="sl-header-bar__phone" href="tel:{{ section.settings.phone_number | replace: ' ', '' }}">
        {{ section.settings.phone_label }}
      </a>
    </div>
  </div>
</div>

<style>
  .sl-header-bar {
    background: #1a1a1a;
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .sl-header-bar .page-width.sl-header-bar__inner {
  max-width: 100%;
}

  .sl-header-bar__inner {
    min-height: 3.6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
  }

  .sl-header-bar__left,
  .sl-header-bar__right {
    display: flex;
    align-items: center;
  }

  .sl-header-bar__left {
    min-width: 0;
  }

  .sl-header-bar__usp {
    font-size: 1.2rem;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.88);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sl-header-bar__right {
    gap: 0.8rem;
    flex-shrink: 0;
  }

  .sl-header-bar__status {
    font-size: 1.2rem;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.7);
    white-space: nowrap;
  }

  .sl-header-bar__phone {
    font-size: 1.2rem;
    line-height: 1.2;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .sl-header-bar__phone:hover {
    opacity: 0.78;
  }

  @media screen and (max-width: 989px) {
    .sl-header-bar__inner {
      min-height: 3.4rem;
      padding-top: 0.6rem;
      padding-bottom: 0.6rem;
    }

    .sl-header-bar__status {
      display: none;
    }

    .sl-header-bar__usp,
    .sl-header-bar__phone {
      font-size: 1.15rem;
    }
  }

  @media screen and (max-width: 749px) {
    .sl-header-bar__inner {
      justify-content: center;
      text-align: center;
    }

    .sl-header-bar__left {
      display: none;
    }

    .sl-header-bar__phone {
      font-size: 1.2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Header USP Bar",
  "tag": "section",
  "class": "section-header-usp-bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "usp_text",
      "label": "USP text",
      "default": "Direkt vom Hersteller"
    },
    {
      "type": "text",
      "id": "status_text",
      "label": "Status Text",
      "default": "Wir sind erreichbar"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Telefon Text",
      "default": "+49 661 4108750"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Telefonnummer für Link",
      "default": "+496614108750"
    }
  ],
  "presets": [
    {
      "name": "Header USP Bar"
    }
  ]
}
{% endschema %}