{% comment %} Figma Source: https://www.figma.com/design/aN5Y2pkIVBDAWQLbNWnr9U/Screenlux-Website?node-id=815-4413&t=c6d9CqTcdjpMd2V5-4 {% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.section_bg_color }};
    display: flex;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .contact-card {
    background-color: {{ section.settings.card_bg_color }};
    color: {{ section.settings.text_color }};
  }
{% endstyle %}

<div class="page-width">
  <div class="contact-card">
    <div class="contact-card__header">
      {% if section.settings.avatar != blank %}
        <div class="contact-card__avatar-wrapper">
          {{ section.settings.avatar | image_url: width: 128 | image_tag: class: 'contact-card__avatar', loading: 'lazy' }}
        </div>
      {% else %}
        <div class="contact-card__avatar-wrapper">
          {{ 'image' | placeholder_svg_tag: 'contact-card__avatar placeholder' }}
        </div>
      {% endif %}
      
      <div class="contact-card__title-area">
        {% if section.settings.name != blank %}
          <h3 class="contact-card__name h3">{{ section.settings.name }}</h3>
        {% endif %}
        {% if section.settings.role != blank %}
          <div class="contact-card__role">{{ section.settings.role }}</div>
        {% endif %}
      </div>
    </div>

    {% if section.settings.description != blank %}
      <div class="contact-card__description rte">
        {{ section.settings.description }}
      </div>
    {% endif %}

    {% if section.settings.contact_label != blank %}
      <div class="contact-card__contact-label h5">
        {{ section.settings.contact_label }}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="contact-card__actions">
        {% for block in section.blocks %}
          {% if block.settings.button_text != blank %}
            <a {% if block.settings.button_link != blank %}href="{{ block.settings.button_link }}"{% else %}role="button"{% endif %} class="button contact-card__button {% if block.settings.button_style == 'primary' %}button--primary{% else %}button--secondary{% endif %}" {{ block.shopify_attributes }}>
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .contact-card {
    max-width: 400px;
    margin: 0 auto;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05), 0 2px 10px rgba(0,0,0,0.02);
    font-family: inherit;
    box-sizing: border-box;
  }
  .contact-card__header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .contact-card__avatar-wrapper {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 8px;
    overflow: hidden;
    background-color: #f4f4f4;
  }
  .contact-card__avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .placeholder {
    padding: 8px;
    fill: #ccc;
  }
  .contact-card__title-area {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .contact-card__name {
    margin: 0;
  }
  .contact-card__role {
    opacity: 0.7;
    margin-top: 4px;
  }
  .contact-card__description {
    margin-bottom: 24px;
  }
  .contact-card__description p:first-child {
    margin-top: 0;
  }
  .contact-card__description p:last-child {
    margin-bottom: 0;
  }
  .contact-card__contact-label {
    margin-bottom: 16px;
    font-weight: 700;
    margin-top: 0;
  }
  .contact-card__actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .contact-card__button {
    width: 100%;
  }
  
  @media screen and (max-width: 749px) {
    .contact-card {
      padding: 24px;
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Card",
  "settings": [
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#121212"
    },
    {
      "type": "image_picker",
      "id": "avatar",
      "label": "Avatar Image"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "Kevin Rebmann"
    },
    {
      "type": "text",
      "id": "role",
      "label": "Role",
      "default": "Sales"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "Description",
      "default": "Short description from sales person, how passionate he is."
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact Label",
      "default": "Contact:"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Label",
          "default": "Book a meeting"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            }
          ],
          "default": "secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Card",
      "blocks": [
        {
          "type": "button",
          "settings": {
            "button_text": "Book a meeting",
            "button_style": "primary",
            "button_link": "mailto:test@example.com"
          }
        },
        {
          "type": "button",
          "settings": {
            "button_text": "Send e-mail",
            "button_style": "secondary",
            "button_link": "mailto:test@example.com"
          }
        },
        {
          "type": "button",
          "settings": {
            "button_text": "Whatsapp",
            "button_style": "secondary",
            "button_link": "https://wa.me/123456789"
          }
        },
        {
          "type": "button",
          "settings": {
            "button_text": "Call me",
            "button_style": "secondary",
            "button_link": "tel:+123456789"
          }
        }
      ]
    }
  ]
}
{% endschema %}
