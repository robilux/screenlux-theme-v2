<!-- Tally Form Embed Script -->
<script>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}</script>

<!-- Wizard Logic -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  // Configured with 4 steps total: 1 = Tiefe, 2 = Montageart, 3 = Verschraubung, 4 = Messen
  let currentStep = 0; // 0=Intro, 1..4=Steps, 99=Beratung
  const selections = {
    method: null,      // beratung | selber
    tiefe: null,       // >=4 | <4
    montageart: null,  // innen | aussen
    verschraubung: null// A | A2 | B
  };

  // DOM Elements
  const progWrapper = document.getElementById('wizard-progress');
  const progFill = document.getElementById('progress-fill');
  const indicators = [
    document.querySelector('.step-ind-1'),
    document.querySelector('.step-ind-2'),
    document.querySelector('.step-ind-3'),
    document.querySelector('.step-ind-4')
  ];
  const labels = [
    document.querySelector('.label-1'),
    document.querySelector('.label-2'),
    document.querySelector('.label-3'),
    document.querySelector('.label-4')
  ];

  const steps = {
    0: document.getElementById('step-0'),
    1: document.getElementById('step-1'),
    2: document.getElementById('step-2'),
    3: document.getElementById('step-3'),
    4: document.getElementById('step-4'),
    99: document.getElementById('step-beratung')
  };

  const nav = document.getElementById('wizard-nav');
  const btnNext = document.getElementById('btn-next');
  const btnBack = document.getElementById('btn-back');

  // Interactive Options
  const optsStep0 = document.getElementById('opts-step0').querySelectorAll('.mg2-card');
  const optsStep1 = document.getElementById('opts-step1').querySelectorAll('.mg2-card');
  const optsStep2 = document.getElementById('opts-step2');
  const optsStep2Cards = optsStep2 ? optsStep2.querySelectorAll('.mg2-card') : [];
  const optsStep3Innen = document.getElementById('opts-step3-innen');
  const optsStep3InnenCards = optsStep3Innen ? optsStep3Innen.querySelectorAll('.mg2-card') : [];

  // Conditional Blocks
  const step2ChoiceContainer = document.getElementById('step2-choice-container');
  const step2OnlyOutside = document.getElementById('step2-only-outside');
  const info2Kassette = document.getElementById('info-2-kassette');
  
  const step3InnenContainer = document.getElementById('step3-innen-container');
  const step3AussenContainer = document.getElementById('step3-aussen-container');
  const info3A = document.getElementById('info-3-A');
  const info3A2 = document.getElementById('info-3-A2');
  
  const measureBlocks = {
    A: document.getElementById('measure-A'),
    A2: document.getElementById('measure-A2'),
    B: document.getElementById('measure-B')
  };

  const bindCards = (cardElements, key, callback) => {
    cardElements.forEach(card => {
      card.addEventListener('click', () => {
        // Skip default/disabled cards (like the auto-selected ones)
        if(card.style.cursor === 'default') return;
        
          cardElements.forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          selections[key] = card.getAttribute('data-choice');
          checkNextStatus();
          if(callback) callback();
        });
      });
    };

  bindCards(optsStep0, 'method');
  bindCards(optsStep1, 'tiefe');
  bindCards(optsStep2Cards, 'montageart', () => {
    if(info2Kassette) info2Kassette.style.display = selections.montageart === 'innen' ? 'block' : 'none';
  });
  bindCards(optsStep3InnenCards, 'verschraubung', () => {
    if(info3A) info3A.style.display = selections.verschraubung === 'A' ? 'block' : 'none';
    if(info3A2) info3A2.style.display = selections.verschraubung === 'A2' ? 'block' : 'none';
  });

  // Checkbox logic
  const checkMeasure = document.getElementById('check-measure');
  const btnConfigure = document.getElementById('btn-configure');
  if(checkMeasure && btnConfigure) {
    checkMeasure.addEventListener('change', (e) => {
      if(e.target.checked) {
        btnConfigure.style.opacity = '1';
        btnConfigure.style.pointerEvents = 'auto';
        btnConfigure.classList.add('mg2-btn-pulse');
      } else {
        btnConfigure.style.opacity = '0.5';
        btnConfigure.style.pointerEvents = 'none';
        btnConfigure.classList.remove('mg2-btn-pulse');
      }
    });
  }

  const deselectGroup = (cardElements) => {
    cardElements.forEach(c => c.classList.remove('selected'));
  };

  // Evaluate "Next" button state
  const checkNextStatus = () => {
    let disabled = true;
    if (currentStep === 0 && selections.method) disabled = false;
    if (currentStep === 1 && selections.tiefe) disabled = false;
    if (currentStep === 2 && selections.montageart) disabled = false;
    if (currentStep === 3 && selections.verschraubung) disabled = false;
    btnNext.disabled = disabled;
  };

  // Render the current step
  const renderStep = () => {
    // Hide all
    Object.values(steps).forEach(el => el.classList.remove('active'));
    
    // Show active
    if (steps[currentStep]) steps[currentStep].classList.add('active');

    // Progress bar visibility
    if (currentStep === 0 || currentStep === 99) {
      progWrapper.style.display = 'none';
    } else {
      progWrapper.style.display = 'block';
      updateProgressFill(currentStep);
    }

    // Logic for Step 2 branching based on Step 1 (Tiefe)
    if (currentStep === 2) {
      if (selections.tiefe === '>=4') {
        step2ChoiceContainer.style.display = 'block';
        step2OnlyOutside.style.display = 'none';
        // Need user to select montageart inside step2
      } else { // <4
        step2ChoiceContainer.style.display = 'none';
        step2OnlyOutside.style.display = 'block';
        selections.montageart = 'aussen'; // auto assign
      }
    }

    // Logic for Step 3 (Verschraubung) based on Step 2 (Montageart)
    if (currentStep === 3) {
      if (selections.montageart === 'innen') {
        step3InnenContainer.style.display = 'block';
        step3AussenContainer.style.display = 'none';
        // Need user to pick A or A2
      } else {
        step3InnenContainer.style.display = 'none';
        step3AussenContainer.style.display = 'block';
        selections.verschraubung = 'B'; // auto assign
      }
    }

    // Logic for Step 4 (Messen) details based on Step 3
    if (currentStep === 4) {
      Object.values(measureBlocks).forEach(b => b.style.display = 'none');
      if(measureBlocks[selections.verschraubung]) measureBlocks[selections.verschraubung].style.display = 'block';
    }

    // Nav controls visibility
    if (currentStep === 0) {
      btnBack.style.visibility = 'hidden';
      btnNext.style.display = 'inline-flex';
    } else if (currentStep === 99) {
      btnBack.style.visibility = 'visible';
      btnNext.style.display = 'none'; 
    } else if (currentStep === 4) {
      btnBack.style.visibility = 'visible';
      btnNext.style.display = 'none'; // End of wizard uses CTA link
    } else {
      btnBack.style.visibility = 'visible';
      btnNext.style.display = 'inline-flex';
    }

    checkNextStatus();
    
    // Auto scroll top slightly after step changes
    if (currentStep > 0 && currentStep !== 99) {
      setTimeout(() => {
        const wrap = document.querySelector('.mg2-wrapper');
        if(wrap) {
           const y = wrap.getBoundingClientRect().top + window.scrollY - 80;
           window.scrollTo({top: y, behavior: 'smooth'});
        }
      }, 50);
    }
  };

  const updateProgressFill = (step) => {
    // 4 steps total: 1->0%, 2->33.3%, 3->66.6%, 4->100%
    const percentage = (step - 1) * 33.3333;
    progFill.style.width = percentage + '%';

    indicators.forEach((ind, i) => {
      ind.classList.remove('active', 'completed');
      labels[i].classList.remove('active');
      
      const indStep = i + 1;
      if (indStep < step) {
        ind.classList.add('completed');
      } else if (indStep === step) {
        ind.classList.add('active');
        labels[i].classList.add('active');
      }
    });
  };

  btnNext.addEventListener('click', () => {
    if (currentStep === 0) {
      if (selections.method === 'beratung') currentStep = 99;
      else currentStep = 1;
    } else if (currentStep < 4) {
      currentStep++;
    }
    renderStep();
  });

  btnBack.addEventListener('click', () => {
    if (currentStep === 99) {
      currentStep = 0;
    } else if (currentStep > 0) {
      currentStep--;
    }
    renderStep();
  });

  // Init
  renderStep();
});
</script>
