        <div class="mg2-formula-card">
          <div class="mg2-formula-title">Dein errechnetes Bestellmaß</div>
          <div class="mg2-formula-row">
            <span>Breite:</span>
            <strong>Gemessenes Maß &ndash; 10 mm</strong>
          </div>
          <div class="mg2-formula-row" style="margin-bottom:0;">
            <span>Höhe:</span>
            <strong>Gemessenes Maß &ndash; 10 mm</strong>
          </div>
        </div>
      </div>

      <!-- Measure Flow A2 -->
      <div id="measure-A2" style="display: none;">
        <ul class="mg2-list" style="margin-bottom: 24px;">
          <li><strong>Breite messen:</strong> Oben, Mitte und Unten messen. Notiere das <em>kleinste</em> Maß.</li>
          <li><strong>Höhe messen:</strong> Links, Mitte und Rechts messen. Notiere das <em>kleinste</em> Maß.</li>
        </ul>
        <div class="mg2-formula-card">
          <div class="mg2-formula-title">Dein errechnetes Bestellmaß</div>
          <div class="mg2-formula-row">
            <span>Breite:</span>
            <strong>Kleinstes Maß &ndash; 3 mm</strong>
          </div>
          <div class="mg2-formula-row" style="margin-bottom:0;">
            <span>Höhe:</span>
            <strong>Kleinstes Maß &ndash; 3 mm</strong>
          </div>
        </div>
