      <!-- Measure Flow B -->
      <div id="measure-B" style="display: none;">
        <ul class="mg2-list" style="margin-bottom: 24px;">
          <li><strong>Fensteröffnung:</strong> Außen auf dem Mauerwerk vollständig die Öffnung messen.</li>
          <li>Messe hierbei horizontal und vertikal immer bis zur äußersten Kante der Öffnung.</li>
        </ul>
        <div class="mg2-formula-card">
          <div class="mg2-formula-title">Dein errechnetes Bestellmaß</div>
           <div class="mg2-formula-row">
            <span>Breite:</span>
