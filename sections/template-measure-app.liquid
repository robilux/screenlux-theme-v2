      measureWidth: {{ 'vindu-uten-ramme-measure-width.png' | asset_url | json }},
      measureHeight: {{ 'vindu-uten-ramme-measure-height.png' | asset_url | json }},
      zipScreenInni: {{ 'zip-screen-inni.png' | asset_url | json }},
      zipScreenUtenpaa: {{ 'zip-screen-utenpaa.png' | asset_url | json }}
